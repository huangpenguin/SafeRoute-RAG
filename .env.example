# --- Local development (unlimited; use your personal ai& key) ---
AIAND_API_KEY=your_aiand_api_key_here

# Optional: real OpenAI key. If unset, public_node also uses ai& (see config/agents.yaml).
OPENAI_API_KEY=

# --- Hugging Face Space demo (set as Repository secrets, NOT in git) ---
# DEMO_MODE=1
# AIAND_API_KEY=your_demo_only_aiand_key
# Or keep AIAND_API_KEY for local and use a separate display key on Space:
# DEMO_AIAND_API_KEY=your_demo_only_aiand_key
#
# Optional tuning (defaults shown):
# DEMO_MAX_QUERIES=10
# DEMO_MAX_QUERY_CHARS=500
# DEMO_MAX_GENERATION_TOKENS=512
